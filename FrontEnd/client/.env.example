# Base URL của API (không kèm /v1 — apiClient tự thêm prefix /v1).
#
# Dev: nếu không set biến này, app dùng mặc định http://localhost:5000 (xem app.config.ts).
#
# Production (Vercel / Netlify / Cloudflare Pages / …): BẮT BUỘC set URL API thật.
# Không dùng localhost — trình duyệt người dùng không thể gọi máy dev của bạn.
VITE_API_URL=https://api.nhongplus.id.vn

# Tuỳ chọn: ép Socket.IO chỉ dùng long-polling (một số mạng chặn WebSocket)
# VITE_SOCKET_FORCE_POLLING=false

# Tuỳ chọn: debug — tắt một phần integrity trong màn làm bài (chỉ dev)
# VITE_DISABLE_INTEGRITY=
