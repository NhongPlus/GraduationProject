    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/async-exit-hook": "^2.0.2",
    "@types/bcrypt": "^6.0.0",
