PORT=5000
APP_PORT=5000
APP_HOST=http://localhost:5173
# Neon database connection
DATABASE_URL=your_database_url
# JWT secret key
JWT_SECRET=your_secret_key
# token expire time
JWT_EXPIRES_IN=7d
# CORS + Socket.IO: danh sách origin, cách nhau bởi dấu phẩy (mặc định trong code: localhost:5173 + https://nhongplus.id.vn)
# CORS_ORIGINS=http://localhost:5173,https://nhongplus.id.vn,https://www.nhongplus.id.vn

# --- SMTP ---
# Dùng Gmail: SMTP_HOST=smtp.gmail.com  |  SMTP_PORT=587  |  SMTP_SECURE=false
# Dùng Resend: SMTP_HOST=smtp.resend.com | SMTP_PORT=587  |  SMTP_SECURE=false
# Dùng Brevo:  SMTP_HOST=smtp-relay.gmail.com (Brevo / Sendinblue dùng SMTP của họ)
# ----------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Online Exam <noreply@yourdomain.com>"

# Chu kỳ quét nhắc hạn (ms), mặc định 600000 = 10 phút
# EXAM_REMINDER_INTERVAL_MS=600000