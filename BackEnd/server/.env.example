PORT=5000
APP_PORT=5000

# URL frontend (link trong email quên mật khẩu)
# Local:     http://localhost:5173
# Production: https://nhongplus.id.vn
APP_HOST=http://localhost:5173

DATABASE_URL=your_database_url
JWT_SECRET=your_secret_key
# Phiên đăng nhập: JWT + session DB (sau hết hạn → 401, client về /login)
JWT_EXPIRES_IN=24h

# CORS + Socket.IO (tùy chọn)
# CORS_ORIGINS=http://localhost:5173,https://nhongplus.id.vn

# =============================================================================
# EMAIL — ai gửi / ai nhận?
# =============================================================================
# MAIL_FROM (from) = Hệ thống / Giáo viên gửi (hiển thị "Online Exam")
# to               = Email SINH VIÊN trong DB (1671020127@student... — tự động, không cấu hình)
#
# --- A) Production trên Render Free (khuyến nghị): Resend HTTPS API ---
# Tạo key tại https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
MAIL_FROM=Online Exam <onboarding@resend.dev>
# Sau khi verify domain: MAIL_FROM=Online Exam <noreply@nhongplus.id.vn>

# --- B) Local dev: Gmail SMTP (tùy chọn, bỏ RESEND_API_KEY khi test Gmail) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# MAIL_FROM=Online Exam <your-email@gmail.com>

EXAM_REMINDER_INTERVAL_MS=600000
